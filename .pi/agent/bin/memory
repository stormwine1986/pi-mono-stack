#!/bin/bash
# .pi/agent/bin/memory
# 记忆系统 CLI —— 供 Agent 调用

MEMORY_URL="${MEMORY_URL:-http://127.0.0.1:18090}"

show_help() {
    echo "Usage: memory <search|list> [options] [query]"
    echo ""
    echo "Actions:"
    echo "  search --user_id=<id> [--threshold=<n>] <query>  检索相关记忆"
    echo "  list --user_id=<id>            获取用户所有记忆"
    echo "  history [options]              查看记忆审计历史"
    echo "      --user_id=<id>             (可选) 按用户过滤"
    echo "      --limit=<n>                (可选) 返回条数，默认 20"
    echo "  status                         查看记忆系统运行时监控指标"
}

if [ -z "$1" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    show_help
    exit 0
fi

case "$1" in
  search)
    shift
    USER_ID=""; QUERY=""; THRESHOLD="0.7"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --user_id=*)   USER_ID="${1#*=}"; shift ;;
        --threshold=*) THRESHOLD="${1#*=}"; shift ;;
        *)             QUERY="$*"; break ;;
      esac
    done
    if [ -z "$USER_ID" ]; then echo "Error: --user_id is required"; exit 1; fi
    curl -s -X POST "${MEMORY_URL}/search" \
      -H "Content-Type: application/json" \
      -d "{\"query\": \"${QUERY}\", \"user_id\": \"${USER_ID}\", \"score_threshold\": ${THRESHOLD}}"
    ;;
  list)
    shift
    USER_ID=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --user_id=*)  USER_ID="${1#*=}"; shift ;;
        *) shift ;;
      esac
    done
    if [ -z "$USER_ID" ]; then echo "Error: --user_id is required"; exit 1; fi
    curl -s "${MEMORY_URL}/memories?user_id=${USER_ID}"
    ;;
  history)
    shift
    USER_ID=""; LIMIT=20
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --user_id=*)  USER_ID="${1#*=}"; shift ;;
        --limit=*)    LIMIT="${1#*=}"; shift ;;
        *) shift ;;
      esac
    done
    URL="${MEMORY_URL}/history?limit=${LIMIT}"
    if [ -n "$USER_ID" ]; then URL="${URL}&user_id=${USER_ID}"; fi
    curl -s "${URL}"
    ;;
  status)
    curl -s "${MEMORY_URL}/metrics" | awk '
      BEGIN {
        print "\033[1;36m🧠 Pi Memory Subsystem Status\033[0m"
        print "------------------------------------------------"
      }
      /^process_resident_memory_bytes/ { rss = $2/1024/1024; rss_str = sprintf("%.2f MB", rss) }
      /^process_cpu_seconds_total/ { cpu_str = sprintf("%.2f s", $2) }
      /^process_open_fds/ { fds = int($2) }
      /^memory_worker_queue_size/ { queue = int($2) }
      /^memory_search_total/ { search = int($2) }
      
      # 捕获带标签的业务指标 (Observer, Extraction/Add, Audit)
      /^(memory_observer_messages_total|memory_extraction_total|memory_audit_events_total)/ && !/_created/ {
        full_name=$1; count=int($2);
        
        # 提取基础名称和标签
        split(full_name, parts, "{");
        base_name = parts[1];
        labels = parts[2];
        gsub(/[}\"]/, "", labels);
        
        # 转换易读名称
        display_name = base_name;
        if (base_name == "memory_observer_messages_total") display_name = "Observer Msg";
        if (base_name == "memory_extraction_total") display_name = "Memory Add";
        if (base_name == "memory_audit_events_total") display_name = "Audit Event";
        
        activity = activity sprintf("  \033[0;90m%-12s\033[0m \033[1;32m%5d\033[0m  \033[0;37m(%s)\033[0m\n", display_name, count, labels)
      }
      
      # 捕获搜索耗时 (Histogram count + sum)
      /^memory_search_duration_seconds_sum/ { s_sum = $2 }
      /^memory_search_duration_seconds_count/ { s_count = $2 }

      END {
        printf "\033[1;33m[ System / 资源状态 ]\033[0m\n"
        printf "  %-18s \033[1;37m%-10s\033[0m\n", "常驻内存 (RSS):", rss_str
        printf "  %-18s \033[1;37m%-10s\033[0m\n", "累计 CPU 时间:", cpu_str
        printf "  %-18s \033[1;37m%-10s\033[0m\n", "文件句柄 (FDs):", fds
        
        printf "\n\033[1;33m[ Execution / 执行情况 ]\033[0m\n"
        q_color = (queue > 0) ? "\033[1;31m" : "\033[1;32m"
        printf "  %-18s %s%-10d\033[0m\n", "任务积压深度:", q_color, queue
        
        avg_search = (s_count > 0) ? (s_sum/s_count)*1000 : 0
        printf "  %-18s \033[1;32m%-10d\033[0m \033[0;90m(Avg: %.1fms)\033[0m\n", "累计搜索请求:", search, avg_search
        
        if (activity != "") {
            printf "\n\033[1;33m[ Activity / 详细计数 ]\033[0m\n"
            printf "%s", activity
        }
        print "------------------------------------------------"
      }
    '
    ;;
  *)
    show_help
    exit 1
    ;;
esac
